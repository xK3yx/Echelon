# PostgreSQL — used by Docker Compose and the backend
DATABASE_URL=postgresql+asyncpg://echelon:echelon@postgres:5432/echelon

# Groq AI — obtain from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# App
DEBUG=false

# Admin API — single shared secret token. Leave empty to disable admin endpoints.
# Generate a strong value with: openssl rand -hex 32
ADMIN_TOKEN=change-me-to-a-long-random-string

# Propose threshold — rule score below which Stage 2.5 LLM career proposal triggers
PROPOSE_THRESHOLD=0.4

# Frontend (public — safe to commit)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Public base URL — used for share links and PDF headers (Phase 7+)
PUBLIC_BASE_URL=http://localhost:3000

# Resume upload (Phase 3+)
# Max upload size in MB. Files larger than this are rejected before parsing.
MAX_UPLOAD_SIZE_MB=5
# Combined heuristic+LLM confidence required to accept a resume parse (0.0–1.0)
RESUME_CONFIDENCE_THRESHOLD=0.4

# Course recommendations (Phase 5+)
# YouTube Data API v3 — https://console.developers.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here
# Tavily Search API — https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
# How many days to cache course recommendations per career slug (default 7)
COURSE_CACHE_TTL_DAYS=7
